<mujoco model="Alfi_Humanoid_Modified"> <!-- Changed model name -->

  <!-- Simulation Options -->
  <option timestep="0.002"/> <!-- Kept timestep from generated, can change back to 0.005 if preferred -->

  <!-- Visual Options -->
  <visual>
    <headlight ambient=".4 .4 .4" diffuse=".8 .8 .8" specular=".1 .1 .1"/>
    <map znear=".01" zfar="30"/> <!-- Adjusted zfar slightly -->
    <quality shadowsize="2048"/>
    <global offwidth="1280" offheight="720"/>
    <rgba haze="0.15 0.25 0.35 1"/> <!-- Added haze like original -->
  </visual>

  <statistic center="0 0 0.7"/> <!-- Copied statistic center -->

  <!-- Assets -->
  <asset>
    <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="32" height="512"/> <!-- Original skybox -->
    <!-- Removed 'body' texture, using direct rgba -->
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
    <!-- Changed geom material to brown -->
    <material name="geom" rgba="0.6 0.4 0.2 1"/>
  </asset>

  <!-- Default Settings - Copied structure from Alfi's Humanoid -->
  <default>
    <motor ctrlrange="-1 1" ctrllimited="true"/>
    <default class="body">
      <!-- geoms -->
      <geom type="capsule" condim="1" friction=".7" solimp=".9 .99 .003" solref=".015 1" material="geom"/>
      <default class="thigh">
        <geom size=".078"/> <!-- Thigh size from original -->
      </default>
      <default class="shin">
         <!-- Shin size/fromto from original -->
        <geom fromto="0 0 0 0 0 -.40182"  size=".05"/>
      </default>
      <default class="foot">
         <!-- Foot capsule size from original -->
        <geom size=".027" />
        <default class="foot1">
          <geom fromto="-.04 -.01 0 .19 -.03 0"/>
        </default>
        <default class="foot2">
          <geom fromto="-.04 .01 0 .19  .03 0"/>
        </default>
      </default>
      <default class="arm_upper">
        <geom size=".04"/>
      </default>
      <default class="arm_lower">
        <geom size=".031"/>
      </default>
      <default class="hand">
        <geom type="sphere" size=".04"/>
      </default>

      <!-- joints -->
      <joint type="hinge" damping="10" stiffness="5" armature=".01" limited="true" solimplimit="0 .99 .01"/>
      <default class="joint_big">
        <joint damping="5" stiffness="10"/>
        <default class="hip_x">
          <joint range="-30 10"/>
        </default>
        <default class="hip_z">
          <joint range="-60 35"/>
        </default>
        <default class="hip_y">
          <joint axis="0 1 0" range="-150 20"/>
        </default>
        <default class="joint_big_stiff">
          <joint stiffness="20"/>
        </default>
      </default>
      <default class="knee">
        <joint pos="0 0 .02" axis="0 -1 0" range="-160 2"/>
      </default>
      <default class="ankle">
        <joint range="-50 50"/>
        <default class="ankle_y">
          <joint pos="0 0 .08" axis="0 1 0" stiffness="62" damping="60"/>
        </default>
        <default class="ankle_x">
          <joint pos="0 0 .04" stiffness="13"/>
        </default>
      </default>
      <default class="shoulder">
        <joint range="-85 60" damping=".2" stiffness="1"/>
      </default>
      <default class="elbow">
        <joint range="-160 0" stiffness="0"/>
      </default>
    </default>
  </default>

  <!-- Model Definition -->
  <worldbody>
    <!-- Floor -->
    <geom name="floor" size="0 0 .05" type="plane" material="grid" condim="3"/>

    <light name="spotlight" mode="targetbodycom" target="torax" diffuse=".8 .8 .8" specular="0.3 0.3 0.3" pos="0 -6 4" cutoff="30"/>

    <!-- Root Body (Torax) - Changed root to torax -->
    <body name="torax" pos="0.165 0 1.396" childclass="body"> <!-- Position from original -->
      <light name="top" pos="0 0 2" mode="trackcom"/>
      <camera name="back" pos="-3 0 1" xyaxes="0 -1 0 1 0 2" mode="trackcom"/>
      <camera name="side" pos="0 -3 1" xyaxes="1 0 0 0 1 2" mode="trackcom"/>
      <!-- track cameras: follow body position exactly (mode="track") -->
      <camera name="track"       pos="-3 0 1"   xyaxes="0 -1 0  1  0 2" mode="track"/>
      <camera name="track_side"  pos="0 -4 1.2" xyaxes="1  0 0  0  0.3 1" mode="track"/>
      <!-- track_front: camera sits 3m in front, looks BACK toward humanoid -->
      <!-- xyaxes: right=(0,1,0)  up=(-1,0,2) => looks in (-2,0,-1) direction -->
      <camera name="track_front" pos="3  0 1"   xyaxes="0  1 0 -1  0 2" mode="track"/>
      <freejoint name="root"/>
      <!-- Torax geom and inertial from original -->
      <geom name="torax" fromto="0 -.12875 0 0 .12875 0" size=".11125"/>
      <inertial pos="0 0 0" mass="16.3625" diaginertia="0.673745 0.1234615 0.673745"/>
      <site name="imu" type="sphere" rgba="0 1 0 .5" pos="0 0 0" size="0.01"/> <!-- Made site visible -->

      <!-- Abdomen (Child of Torax) -->
      <body name="abdomen" pos="0 0 0"> <!-- Position relative to torax (adjust if needed) -->
         <!-- Abdomen geom and inertial from original -->
         <!-- NOTE: Position of geom is relative to THIS body's origin -->
        <geom name="abdomen" fromto="-.01 -.10125 -.215 -.01 .10125 -.215" size=".085"/>
        <inertial pos="-.01 0 -.215" mass="7.4336" diaginertia="0.1841313 0.0326356 .1841313"/>

         <!-- Pelvis (Child of Abdomen) -->
         <!-- NOTE: This body defines the joints connecting to abdomen -->
         <body name="pelvis" pos="-0.02 0 -.46"> <!-- Position from original, relative to abdomen origin -->
            <!-- Abdomen Joints connecting pelvis TO abdomen -->
            <joint name="abdomen_z" pos="0 0 .16" axis="0 0 1" range="-45 3" class="joint_big_stiff"/>
            <joint name="abdomen_y" pos="0 0 .16" axis="0 1 0" range="-75 30" class="joint_big"/>
            <joint name="abdomen_x" pos="0 0 .1" axis="1 0 0" range="-35 35" class="joint_big"/>
            <!-- Pelvis geom and inertial from original -->
            <geom name="butt" fromto="-.0 -.065 0 -.0 .065 0" size=".12"/>
            <inertial pos="0 0 0" mass="13.603889" diaginertia="0.331667 0.130372 0.331667"/>
            <site name="com_accelerometer" type="sphere" rgba="0 1 0 .5" pos="0 0 0" size="0.01"/> <!-- Made site visible -->

            <!-- Right Leg (Child of Pelvis) -->
            <body name="thigh_right" pos="0.04 -.1 -.04"> <!-- Relative to pelvis -->
                <joint name="hip_x_right" axis="1 0 0" class="hip_x" pos="0 0 0.041865"/>
                <joint name="hip_z_right" axis="0 0 1" class="hip_z" pos="0 0 0.041865"/>
                <joint name="hip_y_right" class="hip_y" pos="0 0 0.041865"/>
                <geom name="thigh_right" fromto="0 0 0 0 .01 -.34" class="thigh"/>
                <inertial pos="0 0.005 -0.17" mass="9.6" diaginertia="0.39782263 0.39782263 0.03330608" euler="1.7 0 0"/>
                <body name="shin_right" pos="0.03 .01 -.4"> <!-- Relative to thigh -->
                    <joint name="knee_right" class="knee"/>
                    <geom name="shin_right" class="shin"/>
                    <inertial pos="0 0 -0.20091" mass="4" diaginertia="0.14992478 0.14992478 0.00542691"/>
                    <body name="foot_right" pos="0 0 -.469"> <!-- Relative to shin -->
                        <joint name="ankle_y_right" class="ankle_y" pos="0 0 0.06"/>
                        <joint name="ankle_x_right" class="ankle_x" axis="1 0 0" pos="0 0 0.06"/>
                        <!-- Compound foot from original -->
                        <geom name="foot1_right" class="foot1"/>
                        <geom name="foot2_right" class="foot2"/>
                        <inertial pos="0.075 0 0" mass="1.6" diaginertia="0.009168 0.008528 0.008528"/>
                        <!-- Foot site for sensor -->
                        <site name="foot_right_site" pos="0.075 0 0" size="0.01" rgba="1 0 0 .5"/>
                    </body>
                </body>
            </body>

            <!-- Left Leg (Child of Pelvis) -->
             <body name="thigh_left" pos="0.04 .1 -.04"> <!-- Relative to pelvis -->
                <joint name="hip_x_left" axis="-1 0 0" class="hip_x" pos="0 0 0.041865"/>
                <joint name="hip_z_left" axis="0 0 -1" class="hip_z" pos="0 0 0.041865"/>
                <joint name="hip_y_left" class="hip_y" pos="0 0 0.041865"/>
                <geom name="thigh_left" fromto="0 0 0 0 -.01 -.34" class="thigh"/>
                <inertial pos="0 -0.005 -0.17" mass="9.6" diaginertia="0.39782263 0.39782263 0.03330608" euler="-1.7 0 0"/>
                <body name="shin_left" pos="0.03 -.01 -.4"> <!-- Relative to thigh -->
                    <joint name="knee_left" class="knee"/>
                    <geom name="shin_left" class="shin"/>
                    <inertial pos="0 0 -0.20091" mass="4" diaginertia="0.14992478 0.14992478 0.00542691"/>
                    <body name="foot_left" pos="0 0 -.469"> <!-- Relative to shin -->
                        <joint name="ankle_y_left" class="ankle_y" pos="0 0 0.06"/>
                        <joint name="ankle_x_left" class="ankle_x" axis="-1 0 0" pos="0 0 0.06"/>
                         <!-- Compound foot from original -->
                        <geom name="foot1_left" class="foot1"/>
                        <geom name="foot2_left" class="foot2"/>
                        <inertial pos="0.075 0 0" mass="1.6" diaginertia="0.009168 0.008528 0.008528"/>
                         <!-- Foot site for sensor -->
                        <site name="foot_left_site" pos="0.075 0 0" size="0.01" rgba="1 0 0 .5"/>
                    </body>
                </body>
             </body>
         </body> <!-- End Pelvis -->
      </body> <!-- End Abdomen -->

      <!-- Head (Child of Torax) -->
      <body name="head" pos="0 0 .290"> <!-- Relative to torax -->
          <geom name="head" type="sphere" size=".110"/>
          <!-- Face features on +X (forward) side of head — visual only, no mass/collision -->
          <geom name="eye_right" type="sphere" size=".022" pos=".090 -.042 .025"  rgba="0.1 0.1 0.1 1" contype="0" conaffinity="0" mass="0"/>
          <geom name="eye_left"  type="sphere" size=".022" pos=".090  .042 .025"  rgba="0.1 0.1 0.1 1" contype="0" conaffinity="0" mass="0"/>
          <geom name="nose"      type="sphere" size=".018" pos=".108  .000 -.018" rgba="0.75 0.45 0.2 1" contype="0" conaffinity="0" mass="0"/>
          <camera name="egocentric" pos=".09 0 0" xyaxes="0 -1 0 .1 0 1" fovy="80"/>
          <inertial pos="0 0 0" mass="5.6" diaginertia="0.027104 0.027104 0.027104"/>
          <!-- Neck Joints - Need to define connection TO torax -->
          <!-- These were missing in the original, adding simple ones -->
          <joint name="neck_y" type="hinge" pos="0 0 -0.1" axis="0 1 0" range="-40 40" damping="2"/>
          <joint name="neck_x" type="hinge" pos="0 0 -0.1" axis="1 0 0" range="-30 30" damping="2"/>
      </body>

      <!-- Right Arm (Child of Torax) -->
      <body name="upper_arm_right" pos="0 -.17 .06"> <!-- Relative to torax -->
          <joint name="shoulder1_right" axis="0 0 1" class="shoulder"/>
          <joint name="shoulder2_right" axis="-1 0 0" class="shoulder"/>
          <geom name="upper_arm_right" fromto="0 0 0 0 -.277 0" class="arm_upper"/>
          <inertial pos="0 -0.1385 0" mass="2.4" diaginertia="0.0471207 0.00210599 0.0471207"/>
          <body name="lower_arm_right" pos=".0 -0.318 0"> <!-- Relative to upper arm -->
              <joint name="elbow_right" axis="1 0 0" class="elbow"/>
              <geom name="lower_arm_right" fromto=".0 -.01 .0 .0 -.287 .0" class="arm_lower"/>
              <inertial pos="0 -0.1485 0" mass="1.6" diaginertia="0.02667468 0.00082869 0.02667468"/>
              <body name="hand_right" pos=".0 -.312 0"> <!-- Relative to lower arm -->
                  <geom name="hand_right" zaxis="1 1 1" class="hand"/>
                  <inertial pos="0 0 0" mass="0.8" diaginertia="0.00512 0.00512 0.00512"/>
              </body>
          </body>
      </body>

      <!-- Left Arm (Child of Torax) -->
      <body name="upper_arm_left" pos="0 .17 .06"> <!-- Relative to torax -->
          <joint name="shoulder1_left" axis="0 0 1" class="shoulder"/>
          <joint name="shoulder2_left" axis="1 0 0" class="shoulder"/>
          <geom name="upper_arm_left" fromto="0 0 0 0 0.277 0" class="arm_upper"/>
          <inertial pos="0 0.1385 0" mass="2.4" diaginertia="0.0471207 0.00210599 0.0471207"/>
          <body name="lower_arm_left" pos="0 0.318 0"> <!-- Relative to upper arm -->
              <joint name="elbow_left" axis="1 0 0" class="elbow"/>
              <geom name="lower_arm_left" fromto=".0 .01 .0 0 .287 .0" class="arm_lower"/>
              <inertial pos="0 0.1485 0" mass="1.6" diaginertia="0.02667468 0.00082869 0.02667468"/>
              <body name="hand_left" pos="0 .312 .0"> <!-- Relative to lower arm -->
                  <geom name="hand_left" zaxis="1 -1 1" class="hand"/>
                  <inertial pos="0 0 0" mass="0.8" diaginertia="0.00512 0.00512 0.00512"/>
              </body>
          </body>
      </body>
    </body> <!-- End Torax -->
  </worldbody>

  <!-- Contacts - Copied from original, verify correctness for new structure if needed -->
  <contact>
    <exclude body1="thigh_right" body2="pelvis"/>
    <exclude body1="thigh_left" body2="pelvis"/>
    <exclude body1="foot_left" body2="shin_left"/>
    <exclude body1="shin_left" body2="thigh_left"/>
    <exclude body1="foot_right" body2="shin_right"/>
    <exclude body1="shin_right" body2="thigh_right"/>
    <!-- Added common adjacent limb exclusions -->
    <exclude body1="lower_arm_right" body2="upper_arm_right"/>
    <exclude body1="hand_right" body2="lower_arm_right"/>
    <exclude body1="lower_arm_left" body2="upper_arm_left"/>
    <exclude body1="hand_left" body2="lower_arm_left"/>
    <exclude body1="torax" body2="abdomen"/>
    <exclude body1="abdomen" body2="pelvis"/>
    <exclude body1="torax" body2="head"/>
    <!-- Exclude feet geoms if they might overlap -->
    <!-- <exclude name="foot_geom_exclusion_right" geom1="foot1_right" geom2="foot2_right"/> -->
    <!-- <exclude name="foot_geom_exclusion_left" geom1="foot1_left" geom2="foot2_left"/> -->
  </contact>

  <!-- Tendons - Copied from original -->
  <tendon>
    <fixed name="hamstring_right" limited="true" range="-0.3 2">
      <joint joint="hip_y_right" coef=".5"/>
      <joint joint="knee_right" coef="-.5"/>
    </fixed>
    <fixed name="hamstring_left" limited="true" range="-0.3 2">
      <joint joint="hip_y_left" coef=".5"/>
      <joint joint="knee_left" coef="-.5"/>
    </fixed>
  </tendon>

  <!-- Actuators - Copied gears and joint names from original -->
  <actuator>
    <motor name="abdomen_z"       gear="100"  joint="abdomen_z"/>
    <motor name="abdomen_y"       gear="100"  joint="abdomen_y"/>
    <motor name="abdomen_x"       gear="100"  joint="abdomen_x"/>
    <motor name="hip_x_right"     gear="100"  joint="hip_x_right"/>
    <motor name="hip_z_right"     gear="100"  joint="hip_z_right"/>
    <motor name="hip_y_right"     gear="300" joint="hip_y_right"/>
    <motor name="knee_right"      gear="200"  joint="knee_right"/>
    <motor name="ankle_y_right"   gear="50"  joint="ankle_y_right"/>
    <motor name="ankle_x_right"   gear="50"  joint="ankle_x_right"/>
    <motor name="hip_x_left"      gear="100"  joint="hip_x_left"/>
    <motor name="hip_z_left"      gear="100"  joint="hip_z_left"/>
    <motor name="hip_y_left"      gear="300" joint="hip_y_left"/>
    <motor name="knee_left"       gear="200"  joint="knee_left"/>
    <motor name="ankle_y_left"    gear="50"  joint="ankle_y_left"/>
    <motor name="ankle_x_left"    gear="50"  joint="ankle_x_left"/>
    <motor name="shoulder1_right" gear="25"  joint="shoulder1_right"/>
    <motor name="shoulder2_right" gear="25"  joint="shoulder2_right"/>
    <motor name="elbow_right"     gear="25"  joint="elbow_right"/>
    <motor name="shoulder1_left"  gear="25"  joint="shoulder1_left"/>
    <motor name="shoulder2_left"  gear="25"  joint="shoulder2_left"/>
    <motor name="elbow_left"      gear="25"  joint="elbow_left"/>
    <!-- Added motors for neck joints -->
    <motor name="neck_y" gear="10" joint="neck_y"/>
    <motor name="neck_x" gear="10" joint="neck_x"/>
  </actuator>

  <!-- Sensors - Defined at top level -->
  <sensor>
    <!-- IMU Sensors (use chest_site if chest body exists, otherwise torax?) -->
    <!-- Let's attach to torax imu site -->
    <accelerometer name="accelerometer" site="imu"/>
    <gyro name="gyro" site="imu"/>
    <!-- Alternative: Attach to pelvis com_accelerometer site -->
    <!-- <accelerometer name="com_accel" site="com_accelerometer"/> -->

    <!-- Foot Contact Sensors (linked to foot sites) -->
    <touch name="foot_right_touch" site="foot_right_site"/>
    <touch name="foot_left_touch" site="foot_left_site"/>
  </sensor>

</mujoco>